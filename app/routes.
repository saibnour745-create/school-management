@app.route('/payments/add', methods=['GET', 'POST'])
def add_payment():
    if request.method == 'POST':
        try:
            payment = Payment(
                student_id=request.form.get('student_id'),
                amount=float(request.form.get('amount')),
                month=request.form.get('month'),
                status=request.form.get('status', 'paid')
            )
            db.session.add(payment)
            db.session.flush()
            
            # Enregistrer dans la caisse
            cash_entry = CashRegister(
                transaction_type='income',
                category='tuition',
                amount=payment.amount,
                description=f"Paiement scolarité - {payment.month}",
                student_id=payment.student_id,
                payment_id=payment.id,
                payment_method='cash',
                reference=f"PAY-{payment.id}-{datetime.now().strftime('%Y%m')}",
                created_by='admin'
            )
            db.session.add(cash_entry)
            db.session.commit()
            
            flash('✅ Paiement enregistré avec succès !', 'success')
            return redirect(url_for('payments_list'))
        except Exception as e:
            db.session.rollback()
            flash(f'❌ Erreur : {str(e)}', 'error')
            return redirect(url_for('add_payment'))
    
    students = Student.query.all()
    return render_template('payments/add.html', students=students)

